// Legacy `prisma-client-js` generator. Default output (`node_modules/.prisma/
// client` + `@prisma/client` re-export). Engine binary is bundled per
// `binaryTargets`; the Neon HTTP adapter handles queries at runtime so the
// engine is loaded but unused. See ADR-009 for the engine-less follow-up plan.
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Better Auth models ────────────────────────────────────────────────────────
// Auth identity is separate from domain identity (Account/Profile).
// AuthUser is created by Better Auth on sign-up (email or wallet).
// Account.authUserId links the two layers.

model AuthUser {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  accounts      AuthAccount[]

  // Domain link
  domainAccount Account?
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?

  userId String
  user   AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

// Better Auth's OAuth account table (used for social providers if added later)
model AuthAccount {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  AuthUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
  @@index([userId])
}

// Used by Better Auth for nonce storage (SUI wallet), email verification tokens, etc.
model Verification {
  id         String   @id
  identifier String   // e.g. "sui:0xabc..." or "email:user@example.com"
  value      String   // the nonce or OTP
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

// ── Account ───────────────────────────────────────────────────────────────────
// Domain identity — one per real-world person.
// Created automatically when a user signs up via Better Auth (email or wallet).
// A person owns/is a member of one or more Profiles.
model Account {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lastActiveAt DateTime @default(now())

  // Link to Better Auth identity layer
  authUserId String   @unique
  authUser   AuthUser @relation(fields: [authUserId], references: [id], onDelete: Cascade)

  // Web2 — email mirrored from AuthUser for domain queries
  email String? @unique

  // Web3 — SUI wallet address (optional until connected)
  walletAddress String? @unique

  // Trust & Safety (banning an Account bans all their Profiles)
  isBanned Boolean @default(false)

  // Identity verification tier (per person, not per persona)
  //   NONE:    Unverified — text posts only
  //   BASIC:   Phone or zkLogin — can post images
  //   CREATOR: World ID or stake — can upload audio/video
  //   ARTIST:  Creator + wallet age — can mint NFTs
  identityTier       IdentityTier @default(NONE)
  identityVerifiedAt DateTime?

  // Relations
  profiles       ProfileMember[]
  identityChecks IdentityCheck[]
  devices        UserDevice[]

  @@index([authUserId])
  @@index([walletAddress])
  @@index([email])
}

// ── UserDevice ────────────────────────────────────────────────────────────────
// One row per physical device an Account has signed in on. Stores the device's
// long-term Ed25519 (identity/sign) + X25519 (encrypt) public keys, plus a
// self-signed bundle signature the server verifies at publish time.
//
// Outbound chat send fans-out to every device of every recipient — see
// README §M3 Multi-device. Private keys never leave the device's secure
// enclave / Keychain group `io.sessions.chat`; this table holds public material
// only.
model UserDevice {
  id              String   @id @default(cuid())
  accountId       String
  deviceId        String   // client-generated UUID; stable across re-installs only if seed survives
  ed25519Pub      Bytes    // 32 bytes raw
  x25519Pub       Bytes    // 32 bytes raw
  bundleSignature Bytes    // 64-byte Ed25519 detached sig over 0x01 ‖ deviceId-utf8 ‖ ed25519Pub ‖ x25519Pub
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // MLS (RFC 9420 via OpenMLS) directory columns land here in Chunk 4 —
  // mlsCredentialId + KeyPackage relation. See ADR-015 for the libsignal
  // rejection that drove the swap. No M3.5 signal columns retained.

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, deviceId])
  @@index([accountId])
}

// ── Profile ───────────────────────────────────────────────────────────────────
// Public persona. Posts, follows, NFTs, and reputation all live here.
// One Account can own/be a member of multiple Profiles.
// Examples: a person is both a MUSICIAN and a VENUE owner.
//           a BAND profile has multiple Account members.
model Profile {
  id          String      @id @default(cuid())
  handle      String      @unique // URL-safe slug, e.g. "the-blue-note"
  displayName String
  bio         String?
  avatar      String?
  type        ProfileType
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Trust & Safety
  isBanned    Boolean @default(false)
  reportCount Int     @default(0)

  // Verified = official persona check ("this is the real Boiler Room")
  // Distinct from Account.identityTier which is about the real person
  isVerified Boolean @default(false)

  // Reputation is per-persona — a venue's credibility ≠ their music credibility
  reputation Int @default(0)

  // Relations
  members   ProfileMember[]
  posts     Post[]
  comments  Comment[]
  likes     Like[]
  nfts      NFT[]
  follows   Follow[] @relation("ProfileFollows")   // profiles this profile follows
  followers Follow[] @relation("ProfileFollowers") // profiles following this profile

  @@index([handle])
  @@index([type])
}

enum ProfileType {
  MUSICIAN
  VENUE
  PROMOTER
  VISUAL_ARTIST
  BAND
}

// ── ProfileMember ─────────────────────────────────────────────────────────────
// Join table: Account ↔ Profile with role.
// OWNER  — full control, can delete the profile
// ADMIN  — manage members, post, edit profile
// MEMBER — post as this profile (e.g. band members)
model ProfileMember {
  id        String      @id @default(cuid())
  accountId String
  account   Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  profileId String
  profile   Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  role      ProfileRole @default(OWNER)
  createdAt DateTime    @default(now())

  @@unique([accountId, profileId])
  @@index([accountId])
  @@index([profileId])
}

enum ProfileRole {
  OWNER
  ADMIN
  MEMBER
}

// ── IdentityTier ──────────────────────────────────────────────────────────────
// Lives on Account (the person). Governs all their Profiles.
enum IdentityTier {
  NONE    // Unverified — text posts only
  BASIC   // Phone or zkLogin — can post images
  CREATOR // World ID or stake — can upload audio/video
  ARTIST  // Creator + wallet age — can mint NFTs
}

// ── IdentityCheck ─────────────────────────────────────────────────────────────
// Provider-agnostic verification attempt. One record per attempt.
// Swap verification providers without schema changes.
model IdentityCheck {
  id        String  @id @default(cuid())
  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  // "phone" | "email" | "google_oauth" | "world_id" | "sui_zklogin" | "gitcoin_passport" | "sui_stake"
  provider   String
  externalId String // Provider's session or reference ID

  tier   IdentityTier
  status IdentityCheckStatus

  initiatedAt     DateTime  @default(now())
  resolvedAt      DateTime?
  expiresAt       DateTime? // Stake-based checks expire on stake withdrawal

  // Raw payload for audit trail — never expose to client
  providerPayload Json?

  @@index([accountId])
  @@index([provider, externalId])
}

enum IdentityCheckStatus {
  PENDING  // Awaiting provider callback
  APPROVED
  REJECTED
  EXPIRED
}

// ── Post ──────────────────────────────────────────────────────────────────────
// Belongs to a Profile. Feed is aggregated across followed Profiles.
model Post {
  id        String    @id @default(cuid())
  profileId String
  profile   Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  content   String
  mediaUrls String[]
  mediaType MediaType @default(TEXT)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Denormalised counts — updated via triggers or post-mutation
  likesCount    Int @default(0)
  commentsCount Int @default(0)

  // Trust & Safety
  isHidden    Boolean @default(false)
  reportCount Int     @default(0)

  // Relations
  comments Comment[]
  likes    Like[]
  nft      NFT?

  @@index([profileId])
  @@index([createdAt])
}

enum MediaType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  PERFORMANCE
}

// ── Comment ───────────────────────────────────────────────────────────────────
// Posted as a Profile — you comment as your musician/venue persona.
model Comment {
  id        String  @id @default(cuid())
  postId    String
  post      Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isHidden  Boolean  @default(false)

  @@index([postId])
  @@index([profileId])
}

// ── Like ──────────────────────────────────────────────────────────────────────
// Liked as a Profile. Unique per Profile per Post.
model Like {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, profileId])
  @@index([postId])
  @@index([profileId])
}

// ── Follow ────────────────────────────────────────────────────────────────────
// Profile → Profile. Cross-type follows are valid (musician follows venue, etc).
// Feed query: fetch posts from all profiles where followerId = activeProfileId
model Follow {
  id          String   @id @default(cuid())
  followerId  String
  follower    Profile  @relation("ProfileFollows", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   Profile  @relation("ProfileFollowers", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// ── NFT ───────────────────────────────────────────────────────────────────────
// Minted content on SUI. Belongs to a Profile (the artist/venue persona).
// The Account's walletAddress is the on-chain owner — linked via Profile membership.
model NFT {
  id        String  @id @default(cuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  postId    String? @unique
  post      Post?   @relation(fields: [postId], references: [id], onDelete: SetNull)

  // SUI on-chain identifiers
  objectId  String @unique // SUI object ID
  packageId String          // Smart contract package
  moduleId  String          // Module within package
  type      NFTType

  // Metadata
  name        String
  description String?
  imageUrl    String
  metadataUri String

  // Marketplace
  isListed Boolean @default(false)
  price    String? // SUI tokens as string (avoids float precision loss)

  createdAt DateTime @default(now())

  @@index([profileId])
  @@index([objectId])
}

enum NFTType {
  MUSIC
  PERFORMANCE
  ART
  COLLECTIBLE
}

// ── Chat ──────────────────────────────────────────────────────────────────────
// Direct + small group chats. End-to-end encrypted: server stores only
// ciphertext + nonce, never plaintext or keys.
//
// Membership is at the AuthUser level, not Profile. A person owns the chat,
// not their persona, so identity-tier badges and persona switches do not
// fragment chat history.

model Chat {
  id        String   @id @default(cuid())
  kind      ChatKind @default(DIRECT)
  // Group chats may set a name; direct chats render from the other member.
  name      String?
  createdAt DateTime @default(now())

  members  ChatMember[]
  // No `messages ChatMessage[]` back-relation: ChatMessage drops the FK to
  // simplify partitioning (ADR-014). Messages are queried by chatId via
  // packages/db-edge, never via Prisma joins.

  @@index([createdAt])
}

enum ChatKind {
  DIRECT
  GROUP
}

model ChatMember {
  id     String @id @default(cuid())
  chatId String
  chat   Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  // Member identified by Better Auth user id. Matches the value the chat-ws
  // Worker derives from the bearer token at WS upgrade time.
  userId String
  // For unread counts + read-receipt UX. Updated by the API on read events.
  lastReadAt DateTime?
  joinedAt   DateTime  @default(now())

  @@unique([chatId, userId])
  @@index([userId])
}

// ChatMessage is range-partitioned by month on `createdAt` (ADR-014).
// Prisma manages the parent table schema; partition tables are created by raw
// migration SQL and a scheduled Worker (see `services/chat-ws` future cron).
//
// PK is composite per ADR-012:
//   - chatId      : partition routing key prefix
//   - serverSerial: DO-assigned monotonic counter per chatId (BIGINT)
//   - createdAt   : included in PK so Postgres accepts unique constraints on a
//                   partitioned table (the partition key must be part of every
//                   unique index).
//
// No FK to Chat — Postgres FKs across partitions are per-partition objects and
// fight Prisma's migration model. Membership integrity is enforced at the
// application layer (Worker validates chat exists before insert).
model ChatMessage {
  chatId       String
  serverSerial BigInt
  // Sender is an AuthUser id (matches Session.userId from Better Auth).
  senderId     String
  // Client-generated dedup key (nanoid). Replays after reconnect must not
  // produce duplicate rows — uniqueness is per (chatId, clientMsgId).
  clientMsgId  String
  // Opaque ciphertext + nonce. Server cannot decrypt.
  ciphertext   Bytes
  nonce        Bytes
  createdAt    DateTime @default(now()) @db.Timestamptz()

  @@id([chatId, serverSerial, createdAt])
  @@unique([chatId, clientMsgId, createdAt])
  @@index([chatId, serverSerial])
}
