{
  "name": "@repo/chat-mls-core",
  "version": "0.0.1",
  "private": true,
  "description": "OpenMLS engine for Mortstack Chat — Rust core + UniFFI bindings (see ADR-015)",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./wire": {
      "types": "./src/wire/index.ts",
      "default": "./src/wire/index.ts"
    },
    "./client": {
      "types": "./src/client/index.ts",
      "default": "./src/client/index.ts"
    }
  },
  "scripts": {
    "build:android": "./scripts/build-mls.sh android",
    "build:ios": "./scripts/build-mls.sh ios",
    "build:node": "cd node && pnpm run build",
    "lint": "echo \"rust crate + autogen bindings — skip eslint\" && exit 0",
    "check-types": "tsc --noEmit",
    "test": "if [ -f node/index.node ]; then vitest run; else echo 'chat-mls-core: native binary missing (build with pnpm run build:node) — skipping per Phase 1 single-platform policy'; fi",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@repo/chat-db": "workspace:*",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@noble/ed25519": "^2.3.0",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.10.5",
    "@types/react": "~19.1.10",
    "typescript": "5.9.2",
    "vitest": "^2.1.9"
  },
  "peerDependencies": {
    "expo": "*",
    "react": "*",
    "react-native": "*"
  }
}
