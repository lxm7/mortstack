{
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "jsx": "preserve",
    // Avoids fighting cross-package declaration file incompatibilities
    "skipLibCheck": true
  },
  "exclude": [
    "node_modules",
    // SST — requires .sst/platform/config.d.ts which is generated on first deploy
    ".sst",
    "sst.config.ts",
    "infra",
    "services/upload",
    // Mobile — has its own tsconfig with Expo settings and @/ path aliases
    "apps/mobile",
    // Next.js build outputs — auto-generated, not source
    "**/.next",
    "apps/docs"
  ]
}
