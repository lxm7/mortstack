{
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "jsx": "preserve",
    "skipLibCheck": true
  },
  "exclude": [
    "node_modules",
    ".sst",
    "sst.config.ts",
    "infra",
    "services/upload",
    "apps/mobile",
    "**/.next",
    "apps/docs"
  ],
  "extends": "expo/tsconfig.base"
}
