{
  "name": "my-turborepo",
  "private": true,
  "scripts": {
    "build": "nx run-many -t build",
    "dev": "nx run-many -t dev",
    "lint": "nx run-many -t lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "nx run-many -t check-types"
  },
  "devDependencies": {
    "nx": "22.5.1",
    "prettier": "^3.7.4",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
