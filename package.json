{
  "name": "sessions",
  "private": true,
  "scripts": {
    "build": "nx run-many -t build",
    "dev": "nx run-many -t dev",
    "lint": "nx run-many -t lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "nx run-many -t check-types",
    "prepare": "husky",
    "mobile": "nx run mobile:start",
    "mobile:ios": "nx run mobile:ios",
    "mobile:android": "nx run mobile:android",
    "mobile:prebuild": "nx run mobile:prebuild",
    "mobile:prebuild-clean": "nx run mobile:prebuild-clean",
    "mobile:rebuild-ios": "nx run mobile:rebuild-ios",
    "mobile:rebuild-android": "nx run mobile:rebuild-android"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "nx": "22.5.1",
    "prettier": "^3.7.4",
    "sst": "^3.18.6",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*",
    "infra"
  ],
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "@types/react": "~19.1.10",
    "@types/react-dom": "~19.1.10"
  },
  "version": "1.0.0",
  "lint-staged": {
    "*.{ts,tsx}": "eslint --fix --max-warnings=0",
    "*.{ts,tsx,js,jsx,json,css,md}": "prettier --write"
  }
}
