{
  "name": "mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start --dev-client",
    "start": "expo start --dev-client -c",
    "ios": "expo start --dev-client -c --ios",
    "android": "expo start --dev-client -c --android",
    "prebuild": "expo prebuild",
    "prebuild-clean": "expo prebuild --clean",
    "rebuild-ios": "expo prebuild --clean && expo run:ios",
    "rebuild-android": "expo prebuild --clean && expo run:android",
    "build:ios": "expo run:ios",
    "build:android": "expo run:android",
    "build": "eas build",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@mysten/sui": "^1.15.0",
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@repo/api": "*",
    "@expo-google-fonts/ibm-plex-sans": "^0.3.0",
    "@repo/tailwind-config": "*",
    "@rn-primitives/separator": "^1.2.0",
    "@rn-primitives/slot": "^1.2.0",
    "@tanstack/react-query": "^5.90.21",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "expo": "~54.0.0",
    "expo-build-properties": "~0.14.0",
    "expo-constants": "~18.0.0",
    "expo-dev-client": "~6.0.20",
    "expo-font": "~14.0.0",
    "expo-linking": "~8.0.0",
    "expo-router": "~6.0.0",
    "expo-secure-store": "~15.0.0",
    "expo-splash-screen": "~31.0.0",
    "expo-sqlite": "~16.0.0",
    "expo-status-bar": "~3.0.0",
    "expo-system-ui": "~6.0.9",
    "lucide-react-native": "^0.574.0",
    "nativewind": "^4.1.23",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-mmkv": "^4.1.2",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.11.2",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.17",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "@types/react": "~19.1.10",
    "eslint": "^9.39.1",
    "eslint-config-expo": "^10.0.0",
    "typescript": "5.9.2"
  }
