{
  // Local dev only. Production deploys are managed by SST
  // (`infra/stacks/chat-ws.ts`); SST owns the binding shape and migrations.
  // Keep this file in sync with the SST stack so `wrangler dev` matches prod.
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "chat-ws-dev",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-15",
  // SST's `Resource` import (services/chat-ws/src/auth.ts) pulls process/fs/
  // crypto from Node built-ins. Workers needs nodejs_compat to resolve them.
  // Mirror this in infra/stacks/chat-ws.ts to keep dev/prod parity.
  "compatibility_flags": ["nodejs_compat"],
  "durable_objects": {
    "bindings": [
      { "name": "CHAT", "class_name": "Chat" },
      { "name": "USER_INBOX", "class_name": "UserInbox" }
    ]
  },
  // Edge session cache (ADR-0017). Prod namespace_id is minted by SST
  // (`sst.cloudflare.Kv` in infra/stacks/chat-ws.ts); this local id is a
  // placeholder — `wrangler dev` simulates KV in-process and ignores it.
  "kv_namespaces": [{ "binding": "SESSION_CACHE", "id": "session_cache_local" }],
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["Chat", "UserInbox"]
    }
  ],
  "vars": {
    // Override locally via .dev.vars for the dev API URL.
    "API_INTERNAL_URL": "http://localhost:3001",
    // Edge session cache config (mirrors SST env in chat-ws.ts).
    "SESSION_CACHE_TTL": "120",
    "SESSION_CACHE_ENABLED": "1",
    "SESSION_CACHE_METRICS": "0"
  }
  // DATABASE_URL must be set in .dev.vars locally (not committed). SST
  // injects it in deployed stages; see infra/stacks/chat-ws.ts.
}
