{
  "name": "@repo/api-server",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lambda:build": "esbuild src/lambda.ts --bundle --platform=node --target=node20 --outfile=dist/lambda.js",
    "lint": "eslint .",
    "check-types": "tsc --noEmit",
    "test": "echo \"no tests yet\" && exit 0"
  },
  "dependencies": {
    "@noble/ed25519": "^2.3.0",
    "@repo/chat-crypto": "workspace:*",
    "@repo/chat-mls-core": "workspace:*",
    "@repo/database": "workspace:*",
    "@repo/identity": "workspace:*",
    "@repo/schemas": "workspace:*",
    "@trpc/server": "^11.0.0",
    "better-auth": "^1.3.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/aws-lambda": "^8.10.145",
    "@types/node": "^22.10.5",
    "esbuild": "^0.24.2",
    "eslint": "^9.39.1",
    "tsx": "^4.19.2",
    "typescript": "5.9.2"
  }
}
